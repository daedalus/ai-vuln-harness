{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PoC Result",
  "type": "object",
  "required": ["schema_version", "poc_id", "finding", "harness", "test_cases", "result"],
  "properties": {
    "schema_version": {"type": "string"},
    "poc_id": {"type": "string"},
    "finding": {"type": "object"},
    "harness": {
      "type": "object",
      "required": ["compiler", "flags"],
      "properties": {
        "compiler": {"type": "string"},
        "flags": {"type": "array", "items": {"type": "string"}},
        "link_libs": {"type": "array", "items": {"type": "string"}}
      }
    },
    "test_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "expected", "status"],
        "properties": {
          "name": {"type": "string"},
          "snippet": {"type": "string"},
          "expected": {"type": "string", "enum": ["crash", "clean"]},
          "actual": {"type": "string"},
          "status": {"type": "string", "enum": ["pending", "pass", "fail"]}
        }
      }
    },
    "result": {
      "type": "object",
      "required": ["status", "verdict"],
      "properties": {
        "status": {"type": "string", "enum": ["generated", "compiled", "completed", "build_failed"]},
        "verdict": {"type": "string", "enum": ["confirmed", "rejected", "needs-more-info"]},
        "reasoning": {"type": "string"},
        "exit_code": {"type": "integer"},
        "stdout": {"type": "string"},
        "stderr": {"type": "string"}
      }
    }
  }
}
