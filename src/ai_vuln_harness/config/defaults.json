{
  "mode": "full",
  "is_library_target": true,
  "allow_full_db_fallback": false,
  "enable_localization_stage": false,
  "enable_fuzz_orchestrator": false,
  "enable_pbt": false,
  "sync_default": true,
  "max_workers": 3,
  "cache_file": "output/cache.json",
  "state_db": "output/state.db",
  "suppressions_file": "output/suppressions.json",
  "entry_points": ["ssh_main", "sshd_main", "main", "sftp_server_main", "ssh_agent_main", "ssh_keygen_main", "ssh_keyscan_main", "ssh_keysign_main", "ssh_pkcs11_helper_main"],
  "shield": {
    "min_votes": 2,
    "max_reachability_hops": 6,
    "hallucination_desc_token_threshold": 0.60,
    "hallucination_path_token_threshold": 0.70
  },
  "localization": {
    "max_reachability_hops": 6
  },
  "fuzz_orchestrator": {
    "benchmark_only": true,
    "execute": false,
    "use_valgrind": false,
    "max_targets": 25,
    "max_chain_targets": 10,
    "high_confidence_threshold": 0.75,
    "timeout_seconds": 10
  },
  "pbt": {
    "enable_llm": false,
    "iterations": 500,
    "compile_timeout": 30,
    "run_timeout": 15,
    "max_findings": 50,
    "enabled_languages": ["c", "cpp", "rust", "go", "python", "javascript", "typescript"]
  },
  "validate": {
    "enable_z3_verifier": false,
    "z3_timeout_ms": 50
  },
  "kpis": [
    "precision_at_top_n",
    "reject_rate",
    "duplicate_rate",
    "gap_closure_rate",
    "time_cost_per_stage"
  ],
  "free_tier_profile": {
    "max_workers": 3,
    "retry_per_model": 2,
    "use_async": false
  },
  "paid_tier_profile": {
    "max_workers": 20,
    "retry_per_model": 2,
    "use_async": true
  }
}
