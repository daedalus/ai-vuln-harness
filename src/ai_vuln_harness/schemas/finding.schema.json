{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "snippet_id",
    "severity",
    "class",
    "desc",
    "status",
    "poc_confirmed",
    "bucket_rationale"
  ],
  "properties": {
    "finding_id": {
      "type": "string",
      "description": "Deterministic SHA256-based ID: SHA256(file + class + line_range). Enables cross-agent dedup."
    },
    "snippet_id": {"type": "string"},
    "severity": {
      "type": "string",
      "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFORMATIONAL"]
    },
    "class": {"type": "string"},
    "desc": {"type": "string"},
    "status": {
      "type": "string",
      "enum": ["raw", "confirmed", "rejected", "needs-more-info"]
    },
    "poc_confirmed": {"type": "boolean"},
    "bucket_rationale": {"type": "string"},
    "call_path": {
      "type": "array",
      "items": {"type": "string"}
    },
    "suspicious_points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "function",
          "file",
          "lines",
          "sink_source_type",
          "confidence",
          "rationale",
          "evidence_links"
        ],
        "properties": {
          "function": {"type": "string"},
          "file": {"type": "string"},
          "lines": {
            "type": "array",
            "items": {"type": "integer"}
          },
          "sink_source_type": {"type": "string"},
          "confidence": {"type": "number"},
          "rationale": {"type": "string"},
          "evidence_links": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "pbt_invariant": {
      "type": "string",
      "description": "Property-based testing invariant inferred for this finding"
    },
    "pbt_falsified": {
      "type": "boolean",
      "description": "PBT harness crashed under ASan — invariant falsified"
    },
    "pbt_iterations_run": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of PBT random iterations executed"
    },
    "pbt_confidence_boost": {
      "type": "number",
      "description": "Confidence delta from PBT"
    },
    "pbt_compile_succeeded": {
      "type": "boolean",
      "description": "PBT harness compiled successfully"
    },
    "pbt_skipped": {
      "type": "boolean",
      "description": "PBT was skipped for this finding"
    },
    "pbt_adjusted_confidence": {
      "type": "boolean",
      "description": "localization_confidence was adjusted by PBT"
    },
    "verification_confidence": {
      "type": "object",
      "description": "Structured confidence derived from validation evidence quality.",
      "properties": {
        "grade": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "numeric_score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "basis": {"type": "string"}
      },
      "required": ["grade", "numeric_score", "basis"]
    },
    "code_positions": {
      "type": "array",
      "description": "Labeled affected code locations with designated roles.",
      "items": {
        "type": "object",
        "required": ["role", "file_path", "line_range"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["entrypoint", "wrapper", "guard", "sink", "implementation"]
          },
          "file_path": {"type": "string"},
          "line_range": {"type": "string"},
          "notes": {"type": "string"}
        }
      }
    },
    "source_snippets": {
      "type": "array",
      "description": "Verbatim source excerpts proving the finding, with stable UIDs for cross-referencing.",
      "items": {
        "type": "object",
        "required": ["uid", "designation", "file_path", "line_start", "snippet", "rationale"],
        "properties": {
          "uid": {"type": "string"},
          "designation": {"type": "string"},
          "file_path": {"type": "string"},
          "line_start": {"type": "integer", "minimum": 1},
          "line_end": {"type": "integer", "minimum": 1},
          "lang": {"type": "string"},
          "snippet": {"type": "string"},
          "rationale": {"type": "string"}
        }
      }
    },
    "violation_summary": {
      "type": "object",
      "description": "The violated security invariant and how the implementation breaks it.",
      "properties": {
        "description": {"type": "string"},
        "linked_snippets": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "required": ["description"]
    },
    "exploitation_story": {
      "type": "object",
      "description": "Structured attacker narrative with input flow, access vector, and consequence.",
      "properties": {
        "narrative": {"type": "string"},
        "input_flow": {
          "type": "object",
          "properties": {
            "narrative": {"type": "string"},
            "origin": {"type": "string"},
            "destination": {"type": "string"},
            "consequence": {"type": "string"}
          }
        },
        "access_vector": {
          "type": "object",
          "properties": {
            "narrative": {"type": "string"},
            "actor": {"type": "string"},
            "entrypoint": {"type": "string"},
            "consequence": {"type": "string"}
          }
        },
        "impact": {
          "type": "object",
          "properties": {
            "level": {"type": "string"},
            "rationale": {"type": "string"}
          }
        },
        "linked_snippets": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "classification": {
      "type": "object",
      "description": "Vulnerability family classification with weakness identifiers.",
      "properties": {
        "family": {"type": "string"},
        "weakness_ids": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "suggested_fix": {"type": "string"},
    "fix_verification": {
      "type": "array",
      "items": {"type": "string"}
    },
    "defense_layers": {
      "type": "array",
      "items": {"type": "string"}
    },
    "validation_details": {
      "type": "object",
      "description": "Validation outcome from adversarial review.",
      "properties": {
        "technique": {"type": "string"},
        "outcome": {"type": "string"},
        "linked_snippets": {
          "type": "array",
          "items": {"type": "string"}
        },
        "checklist": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "item": {"type": "string"},
              "passed": {"type": "boolean"},
              "evidence": {"type": "string"}
            }
          }
        }
      }
    },
    "intended_behavior": {
      "type": "string",
      "description": "What was the developer trying to build? The intended, non-vulnerable business logic. Makes the defect legible by contrasting what the code should do vs what it actually does."
    },
    "conditions": {
      "type": "array",
      "description": "Factual prerequisites for exploitation. Empty array if exploitable by default.",
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "authentication_level",
              "authorization_role",
              "user_interaction",
              "system_configuration",
              "network_routing",
              "environmental_dependency",
              "data_state",
              "timing_dependency",
              "third_party_dependency"
            ]
          },
          "description": {"type": "string"}
        },
        "required": ["kind", "description"]
      }
    },
    "baseline_comparable": {
      "type": "object",
      "description": "Comparable mainstream software with the same pattern. If it has been exploited there, the finding is stronger.",
      "properties": {
        "name": {"type": "string"},
        "has_same_pattern": {"type": "boolean"},
        "exploited_there": {"type": "boolean"},
        "notes": {"type": "string"}
      }
    }
  }
}
